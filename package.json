{
  "name": "personal-portfolio-redesign",
  "private": true,
  "scripts": {
    "build": "npm run clean:dist && npm run build:css:dist && npm run build:js:dist && npm run build:copy",
    "build:css": "sass scss/main.scss:css/main.css scss/_resume.scss:css/resume.css --style=compressed --no-source-map",
    "build:css:dist": "sass scss/main.scss:dist/css/main.css scss/_resume.scss:dist/css/resume.css --style=compressed --no-source-map",
    "watch:css": "sass --watch scss/main.scss:css/main.css scss/_resume.scss:css/resume.css --style=expanded --embed-source-map",
    "build:js": "node scripts/build-js.mjs",
    "build:js:dist": "node scripts/build-dist.mjs --js",
    "build:copy": "node scripts/build-dist.mjs --copy",
    "clean:dist": "node scripts/build-dist.mjs --clean",
    "watch:js": "chokidar \"js/*.js\" -i \"js/min/**\" -c \"node scripts/build-js.mjs\"",
    "dev": "run-p watch:css watch:js",
    "deploy": "npm run build && gh-pages -d dist"
  },
  "devDependencies": {
    "chokidar-cli": "^3.0.0",
    "esbuild": "^0.25.2",
    "gh-pages": "^6.3.0",
    "npm-run-all": "^4.1.5",
    "sass": "^1.93.2"
  }
}
