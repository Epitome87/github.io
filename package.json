{
  "name": "personal-portfolio-redesign",
  "private": true,
  "scripts": {
    "build": "npm run clean:dist && npm run build:css:dist && npm run build:js:dist && npm run build:copy",
    "build:css": "sass src/scss/main.scss:src/css/main.css src/scss/_resume.scss:src/css/resume.css --style=compressed --no-source-map",
    "build:css:dist": "sass src/scss/main.scss:dist/css/main.css src/scss/_resume.scss:dist/css/resume.css --style=compressed && postcss dist/css/*.css -d dist/css/",
    "watch:css": "sass --watch src/scss/main.scss:src/css/main.css src/scss/_resume.scss:src/css/resume.css --style=expanded --embed-source-map",
    "build:js": "node scripts/build-js.mjs",
    "build:js:dist": "node scripts/build-dist.mjs --js",
    "build:copy": "node scripts/build-dist.mjs --copy",
    "clean:dist": "node scripts/build-dist.mjs --clean",
    "watch:js": "chokidar \"src/js/*.js\" -i \"src/js/min/**\" -c \"node scripts/build-js.mjs\"",
    "dev": "run-p watch:css watch:js",
    "deploy": "npm run build && gh-pages -d dist"
  },
  "devDependencies": {
    "chokidar-cli": "^3.0.0",
    "cssnano": "^7.1.4",
    "esbuild": "^0.25.2",
    "gh-pages": "^6.3.0",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.8",
    "postcss-cli": "^11.0.1",
    "sass": "^1.93.2"
  }
}
